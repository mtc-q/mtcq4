rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The one admin account. Enforced by Firebase itself — cannot be faked
    // from the browser, unlike a check written in page JavaScript.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'r45t6er7@gmail.com'
        && request.auth.token.email_verified == true;
    }
    function signedIn() { return request.auth != null; }

    // Platform settings: everyone can read (pages need maintenanceMode),
    // only the admin can change them.
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Account profiles: private. A user sees and edits only their own doc;
    // the admin can list, read, edit, and delete any of them.
    match /users/{uid} {
      allow read, delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // Username registry: public reads make availability checks possible.
    // You can only register a name pointing at yourself, and only release
    // names you own. Names are immutable once claimed (no update).
    match /usernames/{name} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Trees: public pages, so anyone can read. Only the owner (or admin)
    // can create, edit, or delete — and a tree's owner field must match
    // the signed-in user and the claimed username registry entry.
    match /trees/{name} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.username == name;
      allow update, delete: if isAdmin()
        || (signedIn() && resource.data.ownerUid == request.auth.uid);
    }

    // Stats: anonymous visitors must be able to bump counters, so writes
    // are open — but shape-checked so only `views` and `clicks` numbers
    // can exist here. Nothing private lives in this collection.
    match /stats/{name} {
      allow read: if true;
      allow delete: if isAdmin()
        || (signedIn() && get(/databases/$(database)/documents/usernames/$(name)).data.uid == request.auth.uid);
      allow create, update: if request.resource.data.keys().hasOnly(['views', 'clicks'])
        && (!('views' in request.resource.data) || request.resource.data.views is int)
        && (!('clicks' in request.resource.data) || request.resource.data.clicks is map);
    }
  }
}
